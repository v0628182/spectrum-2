{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VanySound",
    "version": "1.0.12",
  "identifier": "com.vanysound.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VanySound",
        "width": 1300,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 800,
        "decorations": false,
        "resizable": true,
        "visible": true
      }
    ],
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../instalacion/driver/*": "instalacion/driver/",
      "../instalacion/equalizerapo/*": "instalacion/equalizerapo/",
      "../instalacion/HiFiCableAsioBridgeSetup.exe": "instalacion/HiFiCableAsioBridgeSetup.exe",
      "../instalacion/EchoTools.exe": "instalacion/EchoTools.exe",
      "../instalacion/profiles.bin": "instalacion/profiles.bin",
      "../assets/**/*": "assets/"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.vanysound.com/api/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgNjBEOTg1MDhGRDhFNzUwQg0KUldRTGRZNzlDSVhaWUlYUngzUHhvQjl2UjJYMFF2RGNzZVkrWVFUOG53NWgwU1BwTTNodURkRko="
    }
  }
}
